{
    "schema": {
        "name": "CxxIME",
        "version": "1.0",
        "description": "CxxIME default pinyin schema"
    },
    "engine": {
        "page_size": 9,
        "max_pinyin_length": 64
    },
    "style": {
        "font_face": "Microsoft YaHei UI",
        "font_point": 14,
        "layout": "horizontal",
        "candidate_count": 9,
        "inline_preedit": true,
        "preedit_type": "composition"
    },
    "ascii_composer": {
        "switch_key": {
            "Shift_L": "inline_ascii",
            "Shift_R": "commit_text",
            "Control_L": "noop",
            "Control_R": "noop"
        },
        "good_old_caps_lock": false
    },
    "theme": "light"
}
